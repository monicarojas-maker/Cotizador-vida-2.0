## Calendar (Web Component)

### Anatomía
```
<sb-ui-calendar>
  ├── variant      → "single" | "range" | "multiple"
  ├── size         → "small" | "medium" | "large"
  ├── selected-date  → "YYYY-MM-DD" (modo single)
  ├── selected-dates → "YYYY-MM-DD,YYYY-MM-DD" (modo multiple)
  ├── range-start    → "YYYY-MM-DD" (modo range)
  ├── range-end      → "YYYY-MM-DD" (modo range)
  ├── min-date       → "YYYY-MM-DD"
  ├── max-date       → "YYYY-MM-DD"
  ├── disabled-dates → "YYYY-MM-DD,YYYY-MM-DD"
  ├── locale         → "es" | "en" (default: "es")
  ├── show-footer    → boolean (default: true)
  ├── show-double    → boolean (calendarios dobles, útil en range)
  └── inline         → boolean (sin borde/sombra)
```

### Ejemplos

```html
<!-- Selección única -->
<sb-ui-calendar variant="single"></sb-ui-calendar>

<!-- Con fecha preseleccionada -->
<sb-ui-calendar
  variant="single"
  selected-date="2026-03-15"
></sb-ui-calendar>

<!-- Rango de fechas (doble calendario) -->
<sb-ui-calendar
  variant="range"
  show-double="true"
  range-start="2026-03-01"
  range-end="2026-03-15"
></sb-ui-calendar>

<!-- Selección múltiple -->
<sb-ui-calendar
  variant="multiple"
  selected-dates="2026-03-01,2026-03-10,2026-03-20"
></sb-ui-calendar>

<!-- Con restricciones de fechas -->
<sb-ui-calendar
  variant="single"
  min-date="2026-01-01"
  max-date="2026-12-31"
  disabled-dates="2026-03-08,2026-03-09"
></sb-ui-calendar>

<!-- Inline (sin card) -->
<sb-ui-calendar variant="single" inline></sb-ui-calendar>

<!-- Tamaños -->
<sb-ui-calendar variant="single" size="small"></sb-ui-calendar>
<sb-ui-calendar variant="single" size="medium"></sb-ui-calendar>
<sb-ui-calendar variant="single" size="large"></sb-ui-calendar>
```

### JavaScript API

```javascript
const cal = document.querySelector('sb-ui-calendar');

// Eventos
cal.addEventListener('date-select', (e) => {
  console.log('Fecha seleccionada:', e.detail);
});

cal.addEventListener('date-change', (e) => {
  console.log('Selección cambió:', e.detail);
});

cal.addEventListener('month-change', (e) => {
  console.log('Mes cambió:', e.detail);
});

cal.addEventListener('calendar-accept', (e) => {
  console.log('Aceptado:', e.detail);
});

cal.addEventListener('calendar-cancel', () => {
  console.log('Cancelado');
});
```

