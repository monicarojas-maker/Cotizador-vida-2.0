## Stepper

### Anatomía
```
<div class="sb-ui-stepper sb-ui-stepper--{orientación} [sb-ui-stepper--{tipo}] [sb-ui-stepper--track-dash]">
  └── <div class="sb-ui-stepper__step sb-ui-stepper__step--{estado} [sb-ui-stepper__step--clickable]">
        ├── <div class="sb-ui-stepper__step-circle">
        │     ├── Número / Ícono (contenido)
        │     └── <span class="sb-ui-stepper__step-circle-badge"> (solo variante mix)
        ├── <div class="sb-ui-stepper__step-track"> (línea conectora, auto-oculta en último)
        └── <span class="sb-ui-stepper__step-label">Texto del paso</span>
```

**Orientación:** `--horizontal` (default), `--vertical`
**Tipo de ícono:** *(sin clase)* = número | `--type-icon` = ícono | `--type-mix` = ícono + badge numérico
**Estados del step:** `--empty-active` (actual), `--filled-default` (completado), *(sin clase)* (pendiente)
**Track:** `--track-dash` (líneas punteadas hacia steps pendientes)

### Ejemplos

```html
<!-- Horizontal con números -->
<div class="sb-ui-stepper sb-ui-stepper--horizontal">
  <!-- Completado -->
  <div class="sb-ui-stepper__step sb-ui-stepper__step--filled-default">
    <div class="sb-ui-stepper__step-circle">
      <i class="fa-solid fa-check"></i>
    </div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Datos personales</span>
  </div>
  <!-- Actual -->
  <div class="sb-ui-stepper__step sb-ui-stepper__step--empty-active">
    <div class="sb-ui-stepper__step-circle">2</div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Dirección</span>
  </div>
  <!-- Pendiente -->
  <div class="sb-ui-stepper__step">
    <div class="sb-ui-stepper__step-circle">3</div>
    <!-- Sin track en el último step -->
    <span class="sb-ui-stepper__step-label">Pago</span>
  </div>
</div>

<!-- Vertical con íconos -->
<div class="sb-ui-stepper sb-ui-stepper--vertical sb-ui-stepper--type-icon">
  <div class="sb-ui-stepper__step sb-ui-stepper__step--filled-default">
    <div class="sb-ui-stepper__step-circle">
      <i class="fa-solid fa-check"></i>
    </div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Paso 1</span>
  </div>
  <div class="sb-ui-stepper__step sb-ui-stepper__step--empty-active">
    <div class="sb-ui-stepper__step-circle">
      <i class="fa-solid fa-user"></i>
    </div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Paso 2</span>
  </div>
  <div class="sb-ui-stepper__step">
    <div class="sb-ui-stepper__step-circle">
      <i class="fa-solid fa-credit-card"></i>
    </div>
    <span class="sb-ui-stepper__step-label">Paso 3</span>
  </div>
</div>

<!-- Con líneas punteadas (track-dash) -->
<div class="sb-ui-stepper sb-ui-stepper--horizontal sb-ui-stepper--track-dash">
  <div class="sb-ui-stepper__step sb-ui-stepper__step--filled-default">
    <div class="sb-ui-stepper__step-circle">1</div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Completado</span>
  </div>
  <div class="sb-ui-stepper__step sb-ui-stepper__step--empty-active">
    <div class="sb-ui-stepper__step-circle">2</div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Actual</span>
  </div>
  <div class="sb-ui-stepper__step">
    <div class="sb-ui-stepper__step-circle">3</div>
    <span class="sb-ui-stepper__step-label">Pendiente</span>
  </div>
</div>

<!-- Variante mix (ícono + badge numérico) -->
<div class="sb-ui-stepper sb-ui-stepper--horizontal sb-ui-stepper--type-mix">
  <div class="sb-ui-stepper__step sb-ui-stepper__step--filled-default">
    <div class="sb-ui-stepper__step-circle">
      <span class="sb-ui-stepper__step-circle-badge">1</span>
      <i class="fa-solid fa-check"></i>
    </div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Completado</span>
  </div>
  <div class="sb-ui-stepper__step sb-ui-stepper__step--empty-active">
    <div class="sb-ui-stepper__step-circle">
      <span class="sb-ui-stepper__step-circle-badge">2</span>
      <i class="fa-solid fa-user"></i>
    </div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Actual</span>
  </div>
  <div class="sb-ui-stepper__step">
    <div class="sb-ui-stepper__step-circle">
      <span class="sb-ui-stepper__step-circle-badge">3</span>
      <i class="fa-solid fa-credit-card"></i>
    </div>
    <span class="sb-ui-stepper__step-label">Pendiente</span>
  </div>
</div>

<!-- Steps clickables -->
<div class="sb-ui-stepper sb-ui-stepper--horizontal">
  <div class="sb-ui-stepper__step sb-ui-stepper__step--filled-default sb-ui-stepper__step--clickable"
       onclick="goToStep(1)">
    <div class="sb-ui-stepper__step-circle">1</div>
    <div class="sb-ui-stepper__step-track"></div>
    <span class="sb-ui-stepper__step-label">Paso 1</span>
  </div>
  <div class="sb-ui-stepper__step sb-ui-stepper__step--empty-active sb-ui-stepper__step--clickable"
       onclick="goToStep(2)">
    <div class="sb-ui-stepper__step-circle">2</div>
    <span class="sb-ui-stepper__step-label">Paso 2</span>
  </div>
</div>
```

