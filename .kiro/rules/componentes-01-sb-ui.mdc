<!-- Posicionado sobre un ícono -->
<div style="position: relative; display: inline-block;">
  <i class="fa fa-bell"></i>
  <span class="sb-ui-badge sb-ui-badge--positioned sb-ui-badge--top-right sb-ui-badge--primary">12</span>
</div>

<!-- Dot de estado (sin contenido) -->
<span class="sb-ui-badge sb-ui-badge--dot sb-ui-badge--success"></span>
```

