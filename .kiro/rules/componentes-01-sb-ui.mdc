## Input

### Anatomía
```
.sb-ui-input-container        → Wrapper
  ├── .sb-ui-input-label      → Label
  ├── <div style="position: relative"> (wrapper para icono)
  │     ├── .sb-ui-input      → Input
  │     └── .sb-ui-input-icon → Icono (opcional)
  └── .sb-ui-input-helper     → Helper text
```

**⚠️ NOTA:** Para usar iconos, el input debe tener la clase `sb-ui-input--with-icon` y el icono debe usar la clase `sb-ui-input-icon`. El wrapper del icono debe tener `position: relative`.

### Ejemplos

```html
<!-- Básico -->
<div class="sb-ui-input-container">
  <label class="sb-ui-input-label">Nombre</label>
  <input class="sb-ui-input" type="text" placeholder="Escribe tu nombre">
  <span class="sb-ui-input-helper">
    <i class="fa-solid fa-circle-info"></i>
    Campo obligatorio
  </span>
</div>

<!-- Con icono -->
<div class="sb-ui-input-container">
  <label class="sb-ui-input-label">Email</label>
  <div style="position: relative;">
    <input class="sb-ui-input sb-ui-input--with-icon" type="email" placeholder="email@example.com">
    <span class="sb-ui-input-icon">
      <i class="fa-solid fa-envelope"></i>
    </span>
  </div>
  <span class="sb-ui-input-helper">Ingresa tu email</span>
</div>

<!-- Estados -->
<input class="sb-ui-input" type="text" placeholder="Default">
<input class="sb-ui-input" type="text" disabled placeholder="Disabled">
<input class="sb-ui-input" type="text" readonly value="Read-only">

<!-- Con validación e icono -->
<div class="sb-ui-input-container">
  <label class="sb-ui-input-label">Email</label>
  <div style="position: relative;">
    <input class="sb-ui-input sb-ui-input--success sb-ui-input--with-icon" type="text" value="valid@email.com">
    <span class="sb-ui-input-icon">
      <i class="fa-solid fa-check"></i>
    </span>
  </div>
  <span class="sb-ui-input-helper">Email válido</span>
</div>

<div class="sb-ui-input-container">
  <label class="sb-ui-input-label">Email</label>
  <div style="position: relative;">
    <input class="sb-ui-input sb-ui-input--error sb-ui-input--with-icon" type="text" value="invalid">
    <span class="sb-ui-input-icon">
      <i class="fa-solid fa-xmark"></i>
    </span>
  </div>
  <span class="sb-ui-input-helper">Email inválido</span>
</div>

<div class="sb-ui-input-container">
  <label class="sb-ui-input-label">Email</label>
  <div style="position: relative;">
    <input class="sb-ui-input sb-ui-input--warning sb-ui-input--with-icon" type="text" value="warning">
    <span class="sb-ui-input-icon">
      <i class="fa-solid fa-triangle-exclamation"></i>
    </span>
  </div>
  <span class="sb-ui-input-helper">Revisa tu email</span>
</div>

<!-- Tamaños -->
<input class="sb-ui-input sb-ui-input--small" type="text" placeholder="Small">
<input class="sb-ui-input" type="text" placeholder="Medium (default)">
<input class="sb-ui-input sb-ui-input--large" type="text" placeholder="Large">

<!-- Tipos -->
<input class="sb-ui-input" type="email" placeholder="email@example.com">
<input class="sb-ui-input" type="password" placeholder="••••••••">
<input class="sb-ui-input" type="number" placeholder="0">
<input class="sb-ui-input" type="date">
<input class="sb-ui-input" type="tel" placeholder="+1 (555) 000-0000">
<input class="sb-ui-input" type="url" placeholder="https://example.com">

<!-- Required / Optional -->
<div class="sb-ui-input-container">
  <label class="sb-ui-input-label sb-ui-input-label--required">Email *</label>
  <input class="sb-ui-input" type="email" required>
</div>

<div class="sb-ui-input-container">
  <label class="sb-ui-input-label sb-ui-input-label--optional">Teléfono (opcional)</label>
  <input class="sb-ui-input" type="tel">
</div>
```

