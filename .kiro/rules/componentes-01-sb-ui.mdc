## Ejemplo Completo: CRUD con Modal

```html
<!DOCTYPE html>
<html lang="es" data-brand="seguros-bolivar" data-theme="light">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="https://unpkg.com/@seguros-bolivar/ui-bundle@latest/dist/sb-ui-seguros-bolivar-light.min.css">
  <script type="module" src="https://unpkg.com/@seguros-bolivar/ui-bundle@latest/dist/sb-ui-components.min.js"></script>
  <style>
    body { padding: 2rem; max-inline-size: 1200px; margin-inline: auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-block-end: 2rem; }
    .user-table { inline-size: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; }
    .user-table th, .user-table td { padding: 1rem; text-align: start; border-block-end: 1px solid #e1e1e1; }
    .user-table th { background: #f5f5f5; font-weight: 600; }
    .actions { display: flex; gap: 0.5rem; }
  </style>
</head>
<body>
  <div class="header">
    <h1>Usuarios</h1>
    <button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill" onclick="document.getElementById('modal-new').openModal()">
      Nuevo Usuario
    </button>
  </div>
  
  <table class="user-table">
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Email</th>
        <th>Rol</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Juan Pérez</td>
        <td>juan@example.com</td>
        <td>Admin</td>
        <td class="actions">
          <button class="sb-ui-button sb-ui-button--tertiary sb-ui-button--small sb-ui-button--icon-only">
            <i class="fa-solid fa-pencil"></i>
          </button>
          <button class="sb-ui-button sb-ui-button--error sb-ui-button--small sb-ui-button--icon-only" onclick="confirmDelete('Juan')">
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>
      </tr>
    </tbody>
  </table>
  
  <!-- Modal Nuevo -->
  <sb-ui-modal id="modal-new" title="Nuevo Usuario">
    <form id="form-new" style="display: flex; flex-direction: column; gap: 1rem;">
      <div class="sb-ui-input-container">
        <label class="sb-ui-input-label">Nombre</label>
        <input class="sb-ui-input" type="text" required>
      </div>
      <div class="sb-ui-input-container">
        <label class="sb-ui-input-label">Email</label>
        <input class="sb-ui-input" type="email" required>
      </div>
      <div class="sb-ui-input-container">
        <label class="sb-ui-input-label">Rol</label>
        <select class="sb-ui-select">
          <option>Usuario</option>
          <option>Admin</option>
        </select>
      </div>
    </form>
    
    <div slot="footer">
      <button class="sb-ui-button sb-ui-button--tertiary sb-ui-button--small" onclick="document.getElementById('modal-new').close()">
        Cancelar
      </button>
      <button class="sb-ui-button sb-ui-button--primary sb-ui-button--small" onclick="createUser()">
        Crear
      </button>
    </div>
  </sb-ui-modal>
  
  <!-- Modal Eliminar -->
  <sb-ui-modal id="modal-delete" title="Confirmar" show-close-button="false">
    <p>¿Eliminar a <strong id="delete-name"></strong>?</p>
    <div slot="footer">
      <button class="sb-ui-button sb-ui-button--tertiary sb-ui-button--small" onclick="document.getElementById('modal-delete').close()">
        Cancelar
      </button>
      <button class="sb-ui-button sb-ui-button--error sb-ui-button--small" onclick="deleteUser()">
        Eliminar
      </button>
    </div>
  </sb-ui-modal>
  
  <script>
    function createUser() {
      const form = document.getElementById('form-new');
      if (form.checkValidity()) {
        document.getElementById('modal-new').close();
        form.reset();
      }
    }
    
    function confirmDelete(name) {
      document.getElementById('delete-name').textContent = name;
      document.getElementById('modal-delete').openModal();
    }
    
    function deleteUser() {
      document.getElementById('modal-delete').close();
    }
  </script>
</body>
</html>
```

