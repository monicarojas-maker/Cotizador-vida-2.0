## Checkbox

### Anatomía
```
.sb-ui-checkbox                → Label wrapper
  ├── .sb-ui-checkbox__input   → Input nativo (oculto)
  ├── .sb-ui-checkbox__box     → Box visual
  └── .sb-ui-checkbox__label   → Texto
```

### Ejemplos

```html
<!-- Básico -->
<label class="sb-ui-checkbox">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Acepto términos</span>
</label>

<!-- Checked -->
<label class="sb-ui-checkbox">
  <input type="checkbox" class="sb-ui-checkbox__input" checked>
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Marcado</span>
</label>

<!-- Disabled -->
<label class="sb-ui-checkbox">
  <input type="checkbox" class="sb-ui-checkbox__input" disabled>
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Deshabilitado</span>
</label>

<!-- Error -->
<label class="sb-ui-checkbox sb-ui-checkbox--error">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Campo obligatorio *</span>
</label>

<!-- Tamaños -->
<label class="sb-ui-checkbox sb-ui-checkbox--small">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Small (16px)</span>
</label>

<label class="sb-ui-checkbox">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Medium (20px)</span>
</label>

<label class="sb-ui-checkbox sb-ui-checkbox--large">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Large (24px)</span>
</label>

<!-- Sin label -->
<label class="sb-ui-checkbox sb-ui-checkbox--no-label">
  <input type="checkbox" class="sb-ui-checkbox__input">
  <span class="sb-ui-checkbox__box"></span>
</label>

<!-- Indeterminate (JavaScript) -->
<label class="sb-ui-checkbox">
  <input type="checkbox" class="sb-ui-checkbox__input" id="indeterminate">
  <span class="sb-ui-checkbox__box"></span>
  <span class="sb-ui-checkbox__label">Selección parcial</span>
</label>
<script>
  document.getElementById('indeterminate').indeterminate = true;
</script>
```

