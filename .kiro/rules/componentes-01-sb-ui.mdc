## Modal

### Anatomía
```
<sb-ui-modal>
  ├── title (atributo)
  ├── open (atributo)
  ├── [slot default]
  ├── [slot="header"]
  └── [slot="footer"]
```

### Ejemplos

```html
<!-- Básico -->
<button onclick="document.getElementById('modal1').openModal()">Abrir</button>

<sb-ui-modal id="modal1" title="Mi Modal">
  <p>Contenido</p>
</sb-ui-modal>

<!-- Con footer -->
<sb-ui-modal id="modal2" title="Confirmar">
  <p>¿Continuar?</p>
  
  <div slot="footer">
    <button 
      class="sb-ui-button sb-ui-button--tertiary sb-ui-button--small"
      onclick="document.getElementById('modal2').close()"
    >
      Cancelar
    </button>
    <button 
      class="sb-ui-button sb-ui-button--primary sb-ui-button--small"
      onclick="handleConfirm()"
    >
      Aceptar
    </button>
  </div>
</sb-ui-modal>

<!-- Header personalizado -->
<sb-ui-modal id="modal3">
  <div slot="header" style="display: flex; align-items: center; gap: 0.5rem;">
    <span>🎉</span>
    <span>Custom Header</span>
  </div>
  <p>Contenido</p>
</sb-ui-modal>

<!-- Atributos -->
<sb-ui-modal 
  id="modal4" 
  title="Modal"
  show-close-button="false"
  close-on-backdrop="false"
>
  <p>Sin botón X, no cierra con backdrop</p>
</sb-ui-modal>
```

### JavaScript API

```javascript
const modal = document.getElementById('modal1');

// Abrir
modal.openModal();

// Cerrar
modal.close();

// Eventos
modal.addEventListener('sb-ui-modal-open', () => {
  console.log('Abierto');
});

modal.addEventListener('sb-ui-modal-close', () => {
  console.log('Cerrado');
});

// Estado
console.log(modal.open); // true/false
```

