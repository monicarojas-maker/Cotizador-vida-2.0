## Button

### Anatomía
```
.sb-ui-button                     → Base (OBLIGATORIO)
.sb-ui-button--{variant}          → primary, secondary, tertiary, error
.sb-ui-button--{style}            → stroke, fill, text
.sb-ui-button--{size}             → small, medium, large
.sb-ui-button--{modifier}         → block, rounded, square, circle
.sb-ui-button--icon-{position}    → left, right, only
.sb-ui-button--{state}            → loading, disabled
```

### Ejemplos

```html
<!-- Básico -->
<button class="sb-ui-button sb-ui-button--primary">Primary</button>

<!-- Con estilo fill -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill">Primary Fill</button>

<!-- Icono izquierdo -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill sb-ui-button--icon-left">
  <i class="fa-solid fa-check"></i>
  Guardar
</button>

<!-- Icono derecho -->
<button class="sb-ui-button sb-ui-button--secondary sb-ui-button--stroke sb-ui-button--icon-right">
  Siguiente
  <i class="fa-solid fa-arrow-right"></i>
</button>

<!-- Solo icono -->
<button class="sb-ui-button sb-ui-button--tertiary sb-ui-button--text sb-ui-button--icon-only">
  <i class="fa-solid fa-trash"></i>
</button>

<!-- Disabled -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill sb-ui-button--disabled">Disabled</button>

<!-- Loading -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill sb-ui-button--loading">Loading...</button>

<!-- Tamaños -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--small">Small</button>
<button class="sb-ui-button sb-ui-button--primary">Medium (default)</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--large">Large</button>

<!-- Modificadores -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill sb-ui-button--block">Full Width</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--rounded">Rounded</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--square">Square</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill sb-ui-button--circle sb-ui-button--icon-only">
  <i class="fa-solid fa-plus"></i>
</button>

<!-- Variantes -->
<button class="sb-ui-button sb-ui-button--primary">Primary</button>
<button class="sb-ui-button sb-ui-button--secondary">Secondary</button>
<button class="sb-ui-button sb-ui-button--tertiary">Tertiary</button>
<button class="sb-ui-button sb-ui-button--error">Error</button>

<!-- Estilos -->
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--stroke">Stroke</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--fill">Fill</button>
<button class="sb-ui-button sb-ui-button--primary sb-ui-button--text">Text</button>
```

